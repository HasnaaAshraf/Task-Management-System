
@model TaskManagement.Data.Models.TaskItem;

@{
    ViewData["Title"] = "Edit Task";
}

<body>
    <div class="card d-flex justify-content-center align-content-center bg-light mt-5">
        <div class="auth-container shadow-sm p-4" style="width: 450px;">

            <h2 class="text-center"> Edit Task</h2>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DueTo" class="form-label">Date</label>
                    <input asp-for="DueTo" class="form-control" type="date" />
                    <span asp-validation-for="DueTo" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="IsCompleted" class="form-check-input" type="checkbox" />
                    <label asp-for="IsCompleted" class="form-check-label">Is Completed</label>
                </div>

                <button type="submit" class="btn btn-primary w-100">Edit</button>
                <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Cancel</a>
            </form>

        </div>
    </div>
</body>
